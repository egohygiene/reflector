## chktexrc — ChkTeX configuration for research publication papers.
##
## ChkTeX reference: https://www.nongnu.org/chktex/
## Format reference: /etc/chktexrc
##
## This file configures ChkTeX behaviour for publication manuscripts:
## command spacing, dash rules, math environments, verbatim environments,
## and paper-specific custom warning patterns.
##
## NOTE: Warning-number suppression (-n N) is not supported in this file.
## Suppressed warning numbers are passed as -n flags in scripts/lint-paper.sh
## and documented there with full justifications.

## ---------------------------------------------------------------------------
## QuoteStyle
##
## Controls how ChkTeX checks quotation marks (Warning 18).
## Logical — opening `` and closing '' are required (typographically correct).
## Traditional — only checks for doubled-up characters.
##
## This configuration uses the Logical style: all open quotes must be ``
## and all close quotes must be ''.
QuoteStyle = Logical

## ---------------------------------------------------------------------------
## CmdSpaceStyle
##
## Controls which spacing warnings ChkTeX emits after commands.
##
## Both         — warn on interword (W12) and intersentence (W13) spacing
## InterWord    — warn only on interword spacing
## InterSentence — warn only on intersentence spacing
## Ignore       — do not emit spacing warnings after commands
##
## Academic publications benefit from both: prose spacing matters.
CmdSpaceStyle = Both

## ---------------------------------------------------------------------------
## TabSize
##
## Number of spaces a tab counts as for column numbers in warning output.
TabSize = 4

## ---------------------------------------------------------------------------
## HyphDash / NumDash / WordDash
##
## Acceptable counts of consecutive dashes between different character classes.
## Omitting a count means it is flagged as an error (Warning 8).
##
## HyphDash — between alphabetic characters   (e.g., compound-adjective, well-known)
## NumDash  — between numeric characters      (e.g., pages 10--20, Algorithm 1--3)
## WordDash — between whitespace characters   (e.g., phrase --- emphasis)
##
## NumDash includes 1 to allow hyphens in dates (2026-01-01), ORCID identifiers,
## and other numeric identifiers that use single hyphens.
##
HyphDash { 1 }
NumDash  { 1 2 3 }
WordDash { 3 }

## ---------------------------------------------------------------------------
## Silent
##
## Commands that may be terminated by a space without triggering Warning 1
## ("command terminated with space").  This list appends to the chktex
## defaults defined in /etc/chktexrc.
##
## Publication metadata macros defined in paper/macros/metadata.tex are added
## here so Warning 1 does not fire on \papertitlemain\ or \paperauthor\ etc.
##
Silent
{
    ## Publication metadata macros (paper/macros/metadata.tex)
    \papertitlemain \papertitlesubtitle \papertitlefull
    \paperauthor \paperdate \paperstatus
    \paperorcid \paperorcidurl \paperrepository
    \paperkeywords \papersubject

    ## Abbreviation macros common in academic prose
    \eg \ie \cf \etc \etal \vs
}

## ---------------------------------------------------------------------------
## MathEnvir
##
## LaTeX environments treated as display-math mode.
## This prevents false positives from W38 (dash in math) and W17 (unmatched $).
## Appends to the chktex defaults.
##
MathEnvir
{
    ## Theorem-like environments (add your own as needed)
    definition theorem lemma corollary proposition remark example
    ## AMS starred environments (non-numbered)
    equation* eqnarray* align* alignat* gather* flalign* multiline*
}

## ---------------------------------------------------------------------------
## VerbEnvir
##
## Environments treated as verbatim (linting is suppressed inside them).
## Appends to the chktex defaults.
##
VerbEnvir
{
    lstlisting minted alltt tcblisting
    BVerbatim LVerbatim SaveVerbatim
}

## ---------------------------------------------------------------------------
## UserWarn
##
## Literal strings that trigger Warning 20 when found in the source.
## Use these to catch draft markers that must be replaced before publication.
##
UserWarn
{
    "TODO"
    "FIXME"
    "PLACEHOLDER"
    "TBD"
}
